# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
PORT=5000

# ── LLM Providers — set only what you use ──────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Google Gemini (API Key method) ─────────────────────────────
GOOGLE_API_KEY=AIza...

# ── Google Vertex AI (choose one auth method) ──────────────────
# Option 1: Service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Option 2: Run once in terminal (recommended for dev):
#   gcloud auth application-default login

# Vertex AI project + region
VERTEXAI_PROJECT=my-gcp-project-id
VERTEXAI_LOCATION=us-central1

# ── Ollama (local) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Database file paths (defaults work fine) ───────────────────
# DB_CONNECTIONS_FILE=data/db_connections.json
# USERS_FILE=data/users.json
# LLM_CONFIG_FILE=data/llm_config.json

# ── Rate limiting ───────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379   (optional, uses memory if not set)
